rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.email in ["xxxmastsxxx@gmail.com"];
    }
    match /site/content { allow read: if true; allow write: if isAdmin(); }
    match /site/stats { allow read: if true; allow write: if true; }
  }
}
